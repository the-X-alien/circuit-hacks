---
import { EVENT_NAME, RSVP_URL } from '~/config';

const links = [
  { href: '#about', label: 'About' },
  { href: '#schedule', label: 'Schedule' },
  { href: '#faq', label: 'FAQ' },
  { href: '#parents', label: 'Parents' },
  { href: '#sponsors', label: 'Sponsors' },
];
---

<header class="nav" id="site-nav">
  <a class="brand" href="#top" data-anchor>
    <svg viewBox="0 0 32 32" width="22" height="22" aria-hidden="true">
      <rect x="8" y="8" width="16" height="16" rx="2" fill="none" stroke="currentColor" stroke-width="2"></rect>
      <rect x="13" y="13" width="6" height="6" fill="currentColor"></rect>
      <path
        d="M12 8V4M16 8V4M20 8V4M12 28v-4M16 28v-4M20 28v-4M8 12H4M8 16H4M8 20H4M28 12h-4M28 16h-4M28 20h-4"
        stroke="currentColor"
        stroke-width="1.6"></path>
    </svg>
    <span class="mono">{EVENT_NAME}</span>
  </a>
  <nav aria-label="Sections">
    {links.map((l) => <a href={l.href} data-anchor>{l.label}</a>)}
  </nav>
  <a class="btn btn--primary nav-rsvp" href={RSVP_URL} target="_blank" rel="noopener">
    RSVP <span class="arrow">→</span>
  </a>
</header>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 0.9rem var(--pad);
    transition: background-color 0.4s ease, border-color 0.4s ease,
      transform 1.1s cubic-bezier(0.22, 1, 0.36, 1) 0.45s;
    border-bottom: 1px solid transparent;
  }

  /* Slides in when the preloader releases the page */
  :global(html.js) .nav {
    transform: translateY(-110%);
  }

  :global(html.js.site-entered) .nav {
    transform: translateY(0);
  }

  .nav.is-scrolled {
    background: rgba(10, 10, 10, 0.7);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom-color: var(--line);
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
    color: var(--ink);
    font-size: 0.85rem;
    letter-spacing: 0.12em;
  }

  .brand svg {
    color: var(--cyan);
  }

  nav {
    display: flex;
    gap: clamp(1rem, 2.5vw, 2.2rem);
  }

  nav a {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--ink-dim);
    transition: color 0.3s ease;
  }

  nav a:hover {
    color: var(--ink);
  }

  .nav-rsvp {
    padding: 0.7em 1.6em;
    font-size: 0.72rem;
  }

  @media (max-width: 860px) {
    nav {
      display: none;
    }
  }
</style>
