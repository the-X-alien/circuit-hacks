---
import { RSVP_URL } from '~/config';
import Logo from './Logo.astro';

const links = [
  { href: '#about', label: 'About' },
  { href: '#schedule', label: 'Schedule' },
  { href: '#faq', label: 'FAQ' },
  { href: '#parents', label: 'Parents' },
  { href: '#sponsors', label: 'Sponsors' },
];
---

<header class="nav" id="site-nav">
  <a class="brand" href="#top" data-anchor>
    <Logo size={26} />
  </a>
  <nav aria-label="Sections">
    {links.map((l) => <a href={l.href} data-anchor>{l.label}</a>)}
  </nav>
  <a class="btn btn--primary nav-rsvp" href={RSVP_URL} target="_blank" rel="noopener">
    RSVP <span class="arrow">→</span>
  </a>
</header>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 0.9rem var(--pad);
    transition: background-color 0.4s ease, border-color 0.4s ease,
      transform 1.1s cubic-bezier(0.22, 1, 0.36, 1) 0.45s;
    border-bottom: 1px solid transparent;
  }

  /* Slides in when the preloader releases the page */
  :global(html.js) .nav {
    transform: translateY(-110%);
  }

  :global(html.js.site-entered) .nav {
    transform: translateY(0);
  }

  .nav.is-scrolled {
    background: rgba(10, 10, 10, 0.7);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom-color: var(--line);
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
    color: var(--ink);
    font-size: 0.85rem;
    letter-spacing: 0.12em;
  }

  .brand svg {
    color: var(--gold);
  }

  nav {
    display: flex;
    gap: clamp(1rem, 2.5vw, 2.2rem);
  }

  nav a {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--ink-dim);
    transition: color 0.3s ease;
  }

  nav a:hover {
    color: var(--ink);
  }

  .nav-rsvp {
    padding: 0.7em 1.6em;
    font-size: 0.72rem;
  }

  @media (max-width: 860px) {
    nav {
      display: none;
    }
  }
</style>
