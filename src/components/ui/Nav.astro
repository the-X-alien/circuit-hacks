---
import { RSVP_URL } from '~/config';
import Logo from './Logo.astro';

const links = [
  { href: '#about', label: 'About' },
  { href: '#schedule', label: 'Schedule' },
  { href: '#faq', label: 'FAQ' },
  { href: '#parents', label: 'Parents' },
  { href: '#sponsors', label: 'Sponsors' },
];
---

<header class="nav" id="site-nav">
  <a class="brand" href="#top" data-anchor>
    <Logo size={26} />
  </a>
  <nav aria-label="Sections" id="nav-links">
    {links.map((l) => <a href={l.href} data-anchor>{l.label}</a>)}
  </nav>
  <div class="nav-actions">
    <a class="btn btn--primary nav-rsvp" href={RSVP_URL} target="_blank" rel="noopener">
      RSVP <span class="arrow">→</span>
    </a>
    <button class="nav-toggle" id="nav-toggle" aria-label="Toggle menu" aria-expanded="false">
      <span></span><span></span>
    </button>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const nav = document.getElementById('nav-links');
  if (toggle && nav) {
    toggle.addEventListener('click', () => {
      const open = toggle.getAttribute('aria-expanded') === 'false';
      toggle.setAttribute('aria-expanded', String(open));
      nav.classList.toggle('is-open', open);
      document.documentElement.classList.toggle('nav-open', open);
    });
    // Close on anchor click
    nav.querySelectorAll('a[data-anchor]').forEach((a) =>
      a.addEventListener('click', () => {
        nav.classList.remove('is-open');
        toggle.setAttribute('aria-expanded', 'false');
        document.documentElement.classList.remove('nav-open');
      })
    );
  }
</script>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 0.9rem var(--pad);
    transition: background-color 0.4s ease, border-color 0.4s ease,
      transform 1.1s cubic-bezier(0.22, 1, 0.36, 1) 0.45s;
    border-bottom: 1px solid transparent;
  }

  /* Slides in when the preloader releases the page */
  :global(html.js) .nav {
    transform: translateY(-110%);
  }

  :global(html.js.site-entered) .nav {
    transform: translateY(0);
  }

  .nav.is-scrolled {
    background: rgba(10, 10, 10, 0.7);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom-color: var(--line);
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
    color: var(--ink);
    font-size: 0.85rem;
    letter-spacing: 0.12em;
  }

  .brand svg {
    color: var(--gold);
  }

  nav {
    display: flex;
    gap: clamp(1rem, 2.5vw, 2.2rem);
  }

  nav a {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--ink-dim);
    transition: color 0.3s ease;
  }

  nav a:hover {
    color: var(--ink);
  }

  nav a:nth-child(1):hover { color: var(--gold-bright); }
  nav a:nth-child(2):hover { color: var(--blue); }
  nav a:nth-child(3):hover { color: var(--gold-bright); }
  nav a:nth-child(4):hover { color: var(--blue); }
  nav a:nth-child(5):hover { color: var(--bronze); }

  .nav-rsvp {
    padding: 0.7em 1.6em;
    font-size: 0.72rem;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 32px;
    height: 32px;
    gap: 6px;
    background: transparent;
    border: none;
    cursor: pointer;
    position: relative;
    z-index: 110;
  }

  .nav-toggle span {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--ink);
    border-radius: 2px;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .nav-toggle[aria-expanded="true"] span:nth-child(1) {
    transform: rotate(45deg) translate(3px, 3px);
  }

  .nav-toggle[aria-expanded="true"] span:nth-child(2) {
    transform: rotate(-45deg) translate(3px, -3px);
  }

  @media (max-width: 860px) {
    nav {
      position: fixed;
      top: 0;
      right: 0;
      width: min(320px, 80vw);
      height: 100vh;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      background: rgba(10, 10, 10, 0.95);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      transform: translateX(100%);
      transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
      gap: 2rem;
      z-index: 105;
    }

    nav.is-open {
      transform: translateX(0);
    }

    nav a {
      font-size: 0.9rem;
    }

    .nav-toggle {
      display: flex;
    }
  }

  :global(html.nav-open) {
    overflow: hidden;
  }
</style>
