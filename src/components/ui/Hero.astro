---
import {
  EVENT_NAME,
  EVENT_DATE_SHORT,
  EVENT_YEAR,
  EVENT_LOCATION,
  RSVP_URL,
  TAGLINE,
} from '~/config';

const chars = EVENT_NAME.split('');
const half = Math.floor(chars.length / 2);
---

<section id="top" class="section section--full hero" data-scene="morph">
  <div class="section-inner">
    <p class="hero-meta mono" data-reveal>
      <span>{EVENT_DATE_SHORT} {EVENT_YEAR}</span>
      <span class="dot" aria-hidden="true"></span>
      <span>{EVENT_LOCATION}</span>
      <span class="dot" aria-hidden="true"></span>
      <span>HIGH SCHOOL HARDWARE HACKATHON</span>
    </p>
    <h1 class="display-xl" data-hero-title>
      <span class="hero-highlight" data-hero-chars>
        {chars.map((ch, i) => (
          <span class="hero-char" data-i={i} style={`--i: ${i}; --mid: ${Math.abs(i - half)}`}>
            {ch === ' ' ? '\u00A0' : ch}
          </span>
        ))}
      </span>
    </h1>
    <p class="lede hero-lede" data-reveal>
      <span class="hl">{TAGLINE}</span> <span class="hl-dark">One secret track, sealed until the doors
      open. Build something that exists — then make it blink, move, and think.</span>
    </p>
    <div class="hero-cta" data-reveal>
      <div class="cta-glow" aria-hidden="true"></div>
      <a class="btn btn--primary" href={RSVP_URL} target="_blank" rel="noopener">
        Claim your spot <span class="arrow">→</span>
      </a>
      <a class="btn btn--ghost" href="#about" data-anchor>Enter the signal</a>
    </div>
  </div>
  <div class="hero-scroll mono" aria-hidden="true">
    <span>SCROLL</span>
    <span class="scroll-line"></span>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { bus } from '~/lib/bus';

  const title = document.querySelector('[data-hero-chars]');
  if (title) {
    const chars = title.querySelectorAll<HTMLElement>('.hero-char');

    // Staggered entrance
    gsap.set(chars, { opacity: 0, y: 40, rotateX: -30 });
    const enter = () => {
      gsap.to(chars, {
        opacity: 1,
        y: 0,
        rotateX: 0,
        duration: 0.8,
        stagger: 0.035,
        ease: 'power3.out',
        delay: 0.3,
      });
    };
    window.addEventListener('site:enter', enter, { once: true });

    // Focus-driven middle fade
    const loop = () => {
      const focus = bus.focus;
      const half = Math.floor(chars.length / 2);
      chars.forEach((ch) => {
        const i = parseInt(ch.dataset.i ?? '0');
        const dist = Math.abs(i - half);
        const midWeight = 1 - dist / half;
        const opacity = 1 - midWeight * focus * 0.85;
        ch.style.opacity = String(opacity);
      });
      requestAnimationFrame(loop);
    };
    loop();
  }
</script>

<style>
  .hero {
    text-align: left;
  }

  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    font-size: 0.72rem;
    letter-spacing: 0.28em;
    color: var(--ink-dim);
    margin-bottom: clamp(1.5rem, 3vh, 2.5rem);
  }

  .hero-meta > span:not(.dot) {
    border: 1px solid rgba(111, 168, 214, 0.12);
    background: rgba(111, 168, 214, 0.04);
    padding: 0.1rem 0.6rem;
    border-radius: 4px;
  }

  .dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--gold);
    flex: none;
  }

  h1 {
    margin-bottom: clamp(1.5rem, 3.5vh, 3rem);
  }

  /* Solid gold highlight bar behind the title — dark ink, hugs the text,
     clones cleanly across line breaks. */
  .hero-highlight {
    --hl-pad-x: clamp(0.12em, 0.3vw, 0.22em);
    display: inline;
    background: var(--gold);
    color: #150f03;
    padding: 0.04em var(--hl-pad-x);
    box-decoration-break: clone;
    -webkit-box-decoration-break: clone;
    box-shadow: 0 0 60px -10px rgba(230, 181, 74, 0.5);
  }

  .hero-char {
    display: inline-block;
    color: #150f03;
    transition: opacity 0.15s ease;
    will-change: opacity;
  }

  .hero-lede {
    margin-bottom: clamp(2rem, 4.5vh, 3.4rem);
  }

  .hero-cta {
    position: relative;
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .cta-glow {
    position: absolute;
    inset: -3rem -2rem;
    background: radial-gradient(50% 60% at 30% 40%, rgba(230, 181, 74, 0.08), transparent);
    pointer-events: none;
  }

  .hero-scroll {
    position: absolute;
    bottom: 2.2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.8rem;
    font-size: 0.6rem;
    letter-spacing: 0.4em;
    color: var(--ink-faint);
  }

  .scroll-line {
    width: 1px;
    height: 52px;
    background: linear-gradient(var(--ink-faint), transparent);
    overflow: hidden;
    position: relative;
  }

  .scroll-line::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(var(--gold), transparent);
    animation: scroll-hint 2.2s cubic-bezier(0.65, 0, 0.35, 1) infinite;
  }

  @keyframes scroll-hint {
    0% { transform: translateY(-100%); }
    60%, 100% { transform: translateY(100%); }
  }
</style>
