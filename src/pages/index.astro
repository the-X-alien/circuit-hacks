---
import Base from '~/layouts/Base.astro';
import Preloader from '~/components/ui/Preloader.astro';
import Nav from '~/components/ui/Nav.astro';
import CustomCursor from '~/components/ui/CustomCursor.astro';
import AudioToggle from '~/components/ui/AudioToggle';
import Experience from '~/components/experience/Experience';
import Hero from '~/components/ui/Hero.astro';
import About from '~/components/ui/About.astro';
import Details from '~/components/ui/Details.astro';
import ThemeTease from '~/components/ui/ThemeTease.astro';
import Schedule from '~/components/ui/Schedule.astro';
import Bring from '~/components/ui/Bring.astro';
import ParentInfo from '~/components/ui/ParentInfo.astro';
import FaqSection from '~/components/ui/FaqSection.astro';
import Sponsors from '~/components/ui/Sponsors.astro';
import Team from '~/components/ui/Team.astro';
import Cta from '~/components/ui/Cta.astro';
import Footer from '~/components/ui/Footer.astro';
---

<Base>
  <Preloader />
  <Experience client:only="react" />
  <Nav />
  <CustomCursor />
  <AudioToggle client:idle />

  <div id="smooth-wrapper">
    <div id="smooth-content">
      <main>
        <Hero />
        <About />
        <Details />
        <ThemeTease />
        <Schedule />
        <Bring />
        <ParentInfo />
        <FaqSection />
        <Sponsors />
        <Team />
        <Cta />
      </main>
      <Footer />
    </div>
  </div>
</Base>

<script>
  import { initSite } from '~/scripts/main';
  initSite();
</script>
